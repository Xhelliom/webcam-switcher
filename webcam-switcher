#!/usr/bin/env bash
# webcam-switcher — on-demand internal IPU6 (ov08x40) webcam via v4l2loopback.
#
#   Idle: a black splash continuously feeds the loopback (/dev/video0) so the
#         device stays LISTED (Teams/Chrome see it), but libcamera is NOT running
#         -> the sensor and its privacy LED stay OFF.
#   In use: as soon as an app opens the loopback (Teams, Meet, OBS, Zoom...), it
#         switches to the real camera (libcamera software ISP debayered on the
#         Intel iGPU via Mesa) -> LED on, ~21 fps 720p. Back to the splash (LED
#         off) as soon as the app releases the device.
#
# Why this contraption (see README):
#   - Hybrid Intel iGPU + NVIDIA dGPU: libcamera picks the NVIDIA EGL by default,
#     whose driver fails the framebuffer -> we force the Mesa/Intel EGL vendor.
#   - ov08x40 caps the binned (720p/1080p) mode at ~3.6 fps but does ~28 fps in
#     full 3856x2160 mode -> we capture full-frame and videoscale down to 720p.
#   - v4l2-relayd (the usual on-demand tool) crashes at pipeline construction on
#     this setup -> this ~40-line switcher replaces it.
set -u

DEV="${WEBCAM_DEV:-/dev/video0}"
WIDTH="${WEBCAM_WIDTH:-1280}"
HEIGHT="${WEBCAM_HEIGHT:-720}"
GRACE="${WEBCAM_GRACE:-3}"          # seconds of grace before falling back (anti-flapping)
MESA_VENDOR=/usr/share/glvnd/egl_vendor.d/50_mesa.json

# Force the software ISP onto the Intel iGPU (Mesa), not the NVIDIA dGPU.
export __EGL_VENDOR_LIBRARY_FILENAMES="$MESA_VENDOR"
export LIBCAMERA_SOFTISP_MODE=gpu

splash() {
  exec gst-launch-1.0 -q videotestsrc pattern=black is-live=true \
    ! video/x-raw,format=YUY2,width="$WIDTH",height="$HEIGHT",framerate=10/1 \
    ! v4l2sink device="$DEV" sync=false
}
camera() {
  exec gst-launch-1.0 -q libcamerasrc \
    ! video/x-raw,width=3840,height=2160 \
    ! videoscale ! video/x-raw,width="$WIDTH",height="$HEIGHT" \
    ! videoconvert ! video/x-raw,format=YUY2 \
    ! v4l2sink device="$DEV" sync=false
}

PID=0; MODE=""
start() { ( "$1" ) & PID=$!; MODE="$1"; }
stopp() { [ "$PID" -gt 0 ] && { kill "$PID" 2>/dev/null; wait "$PID" 2>/dev/null; }; PID=0; }
trap 'stopp; exit 0' INT TERM

# Wait for the loopback to exist (module loaded at boot).
for _ in $(seq 1 30); do [ -e "$DEV" ] && break; sleep 1; done
[ -e "$DEV" ] || { echo "webcam-switcher: $DEV not found" >&2; exit 1; }

start splash
gone=0
while sleep 1; do
  # respawn the producer if it died
  kill -0 "$PID" 2>/dev/null || start "$MODE"

  # a consumer = any PID holding $DEV that is not our own producer
  cons=0
  for p in $(fuser "$DEV" 2>/dev/null | grep -oE '[0-9]+'); do
    [ "$p" = "$PID" ] || cons=1
  done

  if [ "$cons" = 1 ]; then
    gone=0
    [ "$MODE" = splash ] && { stopp; start camera; }
  elif [ "$MODE" = camera ]; then
    gone=$((gone + 1))
    [ "$gone" -ge "$GRACE" ] && { stopp; start splash; gone=0; }
  fi
done
